{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|webp|svg|gif|jpg|jpeg|ico|txt|woff|woff2|ttf|otf|map|webmanifest))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
